# Database
DB_URL=jdbc:mysql://your-mysql-host:3306/knowall?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASS=your-db-password
DB_NAME=knowall

# AI / DashScope
AI_API_KEY=your-dashscope-api-key
AI_BASE_URL=https://your-proxy-domain/v1
AI_MODEL=glm/glm-5
DASHSCOPE_API_KEY=your-dashscope-direct-api-key
VL_MODEL=qwen3.6-plus
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=CHERRY

# MinIO
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tts-audio

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION=604800000
